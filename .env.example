# Copy this file to ".env" (same folder as merged88.py / merged89.py) and
# fill in your real camera details. ".env" is gitignored and will never be
# committed - only this example template is tracked.

HOTSAW_CAM_USER=admin
HOTSAW_CAM_PASS=your_camera_password
HOTSAW_CAM_HOST=192.168.1.100
HOTSAW_CAM_PORT=554
